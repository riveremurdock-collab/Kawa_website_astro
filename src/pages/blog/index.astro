---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import RouteMap from '../../components/RouteMap.astro';
import InstagramEmbed from '../../components/InstagramEmbed.astro';
import InstagramInline from '../../components/InstagramInline.astro';
import PhotoInline from '../../components/PhotoInline.astro';

const articles = await getCollection('articles');
const sortedArticles = articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featuredArticle = sortedArticles[0];
let Content = null;
if (featuredArticle) {
    const rendered = await featuredArticle.render();
    Content = rendered.Content;
}

const hasGpxRoute = !!(featuredArticle?.data.gpxRoute?.file);
---

<BlogLayout
    title="Kawa Blog"
    description="Kawa Designs blog — adventure stories and route reports"
    articles={sortedArticles}
    currentSlug={featuredArticle?.slug}
    loadGallery={true}
>
    {featuredArticle && Content ? (
        <article class="article">
            <header class="article-header">
                <h1>{featuredArticle.data.title}</h1>
                <div class="article-meta">
                    <time datetime={featuredArticle.data.date.toISOString()}>
                        {featuredArticle.data.date.toLocaleDateString('en-US', {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric'
                        })}
                    </time>
                    <div class="article-tags">
                        {featuredArticle.data.tags.map(tag => (
                            <span class="tag">{tag}</span>
                        ))}
                    </div>
                </div>
            </header>

            {hasGpxRoute && (
                <RouteMap
                    gpxFile={featuredArticle.data.gpxRoute.file}
                    title={featuredArticle.data.gpxRoute.title || "Route Map"}
                    showElevation={featuredArticle.data.gpxRoute.showElevation !== false}
                    height={featuredArticle.data.gpxRoute.mapHeight || "450px"}
                />
            )}

            {featuredArticle.data.images && featuredArticle.data.images.length > 0 && (
                <div class="article-gallery-container" data-images={JSON.stringify(featuredArticle.data.images.map(img => ({
                    src: typeof img.src === 'string' ? img.src : img.src.src,
                    alt: img.alt,
                    caption: img.caption
                })))}>
                    {featuredArticle.data.images.map((image, index) => (
                        <div class="article-gallery">
                            <div class="gallery-item" data-index={index}>
                                {typeof image.src === 'string' ? (
                                    <img src={image.src} alt={image.alt} loading="lazy" />
                                ) : (
                                    <Image src={image.src} alt={image.alt} loading="lazy" />
                                )}
                                {image.caption && <span class="caption">{image.caption}</span>}
                            </div>
                        </div>
                    ))}
                </div>
            )}

            <div class="article-body">
                <Content components={{ InstagramEmbed, InstagramInline, PhotoInline }} />
            </div>

            <div class="comments-section">
                <h2>Comments</h2>
                <div id="cusdis_thread"
                    data-host="https://cusdis.com"
                    data-app-id="e5efd1f2-ea0a-4da1-b432-df5979658893"
                    data-page-id={featuredArticle.slug}
                    data-page-url={Astro.url.href}
                    data-page-title={featuredArticle.data.title}
                ></div>
                <script async defer src="https://cusdis.com/js/cusdis.es.js"></script>
            </div>
        </article>
    ) : (
        <div class="loading-message">No articles found.</div>
    )}

    {hasGpxRoute && (
        <Fragment>
            <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
            <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
            <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/leaflet-gpx/1.7.0/gpx.min.js"></script>
            <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
            <script is:inline src="/scripts/route-map.js"></script>
        </Fragment>
    )}
</BlogLayout>
