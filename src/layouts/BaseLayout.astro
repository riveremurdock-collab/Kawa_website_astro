---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import InventoryMenu from '../components/InventoryMenu.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  articles: Array<{
    slug: string;
    data: {
      title: string;
      date: Date;
      tags: string[];
    };
  }>;
  currentSlug?: string;
}

const { title, description, articles, currentSlug } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <BaseHead title={title} description={description} />
</head>
<body>
    <!-- Inventory Menu Overlay -->
    <InventoryMenu />

    <!-- Page Wrapper (for layout) -->
    <div id="page-wrapper">
        <!-- Header -->
        <Header />

        <!-- Sidebar (Menu & Posts) -->
        <Sidebar articles={articles} currentSlug={currentSlug} />

        <!-- Main Content -->
        <main id="main-content">
            <slot />
        </main>
    </div>

    <!-- Scripts -->
    <script src="/scripts/menu.js" is:inline></script>
    <script src="/scripts/gallery.js" is:inline></script>
    <script src="/scripts/audio.js" is:inline></script>
</body>
</html>
