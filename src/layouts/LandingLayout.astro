---
interface Props {
    title?: string;
    description?: string;
}
const { title = "Kawa Designs", description = "Kawa Designs — outdoor adventure blog and design" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/images/logos/kawa favicon.png" />
    <style>
        @font-face {
            font-family: 'AveriaLibre';
            src: url('/fonts/Averia_Libre/AveriaLibre-Regular.ttf') format('truetype');
            font-weight: 400;
            font-style: normal;
            font-display: swap;
        }
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { width: 100%; height: 100%; overflow: hidden; }
        img { max-width: 100%; height: auto; }
        a { text-decoration: none; }
    </style>
</head>
<body>
    <slot />
</body>
</html>
