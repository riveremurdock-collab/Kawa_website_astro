---
interface Props {
  slug: string;
  title: string;
  date: Date;
  tags: string[];
  isActive?: boolean;
}

const { slug, title, date, tags, isActive = false } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
});
---

<li data-tags={tags.join(',')}>
    <a href={`/articles/${slug}`} class:list={['article-link', { active: isActive }]}>
        <span class="article-title">{title}</span>
        <span class="article-date">{formattedDate}</span>
    </a>
</li>
