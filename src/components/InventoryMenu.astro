---
---

<!-- Inventory Menu Overlay -->
<div id="inventory-overlay" class="hidden" aria-hidden="true">
    <div id="inventory-window" role="dialog" aria-label="Inventory Menu">
        <div class="inventory-frame">
            <button class="inventory-close" aria-label="Close menu">ESC</button>
            <div class="inventory-grid">
                <!-- Row 1 -->
                <div class="inventory-slot" data-item="about">
                    <div class="slot-icon about-icon"></div>
                    <span class="slot-label">About</span>
                </div>
                <div class="inventory-slot" data-item="events">
                    <div class="slot-icon events-icon"></div>
                    <span class="slot-label">Events</span>
                </div>
                <div class="inventory-slot" data-item="social">
                    <div class="slot-icon social-icon"></div>
                    <span class="slot-label">Social</span>
                </div>
                <!-- Row 2 -->
                <div class="inventory-slot" data-item="shopping">
                    <div class="slot-icon shop-icon"></div>
                    <span class="slot-label">Shop</span>
                </div>
                <div class="inventory-slot" data-item="contact">
                    <div class="slot-icon contact-icon"></div>
                    <span class="slot-label">Contact</span>
                </div>
                <div class="inventory-slot" data-item="radio">
                    <div class="slot-icon radio-icon"></div>
                    <span class="slot-label">Radio</span>
                </div>
                <!-- Row 3 -->
                <div class="inventory-slot" data-item="sword">
                    <div class="slot-icon sword-icon"></div>
                    <span class="slot-label">Sword</span>
                </div>
                <div class="inventory-slot" data-item="skull">
                    <div class="slot-icon skull-icon"></div>
                    <span class="slot-label">Skull</span>
                </div>
                <div class="inventory-slot" data-item="guestbook">
                    <div class="slot-icon flower-icon"></div>
                    <span class="slot-label">Logbook</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Popup Windows Container -->
<div id="popup-container" aria-live="polite"></div>
