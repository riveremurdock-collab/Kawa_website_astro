---
import MenuButton from './MenuButton.astro';
import PostsList from './PostsList.astro';

interface Props {
  articles: Array<{
    slug: string;
    data: {
      title: string;
      date: Date;
      tags: string[];
    };
  }>;
  currentSlug?: string;
}

const { articles, currentSlug } = Astro.props;
---

<!-- Menu Section -->
<aside class="sidebar-box sidebar-menu-box">
    <MenuButton />
</aside>

<!-- Posts Section -->
<aside class="sidebar-box sidebar-posts-box">
    <PostsList articles={articles} currentSlug={currentSlug} />
</aside>
